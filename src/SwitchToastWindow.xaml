<Window x:Class="WindowsLosslessSwitcher.SwitchToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Toast"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">
  <Border Padding="14"
          Background="#FFF8F5EC"
          BorderBrush="#FFB45309"
          BorderThickness="1"
          CornerRadius="12"
          SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="18"
                        ShadowDepth="3"
                        Opacity="0.22"
                        Color="#33000000" />
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="TitleTextBlock"
                 Grid.Row="0"
                 Grid.Column="0"
                 Margin="0,0,12,0"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#FF111827"
                 Text="Switched audio format" />

      <Button Grid.Row="0"
              Grid.Column="1"
              Width="24"
              Height="24"
              Padding="0"
              Click="CloseButton_OnClick"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
              Focusable="False"
              ToolTip="Dismiss notification">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#FF6B7280"
                   Text="X" />
      </Button>

      <TextBlock x:Name="MessageTextBlock"
                 Grid.Row="1"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 Margin="0,8,0,0"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="#FF92400E"
                 Text="24-bit / 96 kHz" />

      <TextBlock x:Name="TrackDetailsTextBlock"
                 Grid.Row="2"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 Margin="0,8,0,0"
                 Foreground="#FF374151"
                 TextWrapping="Wrap"
                 Visibility="Collapsed" />

      <TextBlock x:Name="DeviceTextBlock"
                 Grid.Row="3"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 Margin="0,6,0,0"
                 Foreground="#FF374151"
                 TextWrapping="Wrap"
                 Visibility="Collapsed" />
    </Grid>
  </Border>
</Window>
